# PantryPal environment example
# Copy this file to `.env` for local development and fill in real values.
# Keep `.env` private. Do not commit real API keys.

# OpenAI-compatible LLM configuration.
# For Berget.AI or another compatible provider, set the provider's base URL.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.berget.ai/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# Local data and memory.
# Defaults are usually fine when running from the assignment_2 directory.
PANTRYPAL_DATA_DIR=data
PANTRYPAL_MEMORY_DIR=data
PANTRYPAL_RETRIEVAL_CONFIDENCE_THRESHOLD=0.35

# Web search fallback.
# `mock` works offline and requires no API key. Use `disabled` to turn it off.
# Use `http` only if you have configured a compatible JSON search endpoint.
PANTRYPAL_WEB_SEARCH_PROVIDER=mock
PANTRYPAL_WEB_SEARCH_ENDPOINT=
PANTRYPAL_WEB_SEARCH_API_KEY=

# Logging.
PANTRYPAL_LOG_LEVEL=WARNING
